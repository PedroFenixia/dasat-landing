---
export interface Props { size?: number; soft?: boolean; }
const { size = 64, soft = false } = Astro.props;
---
<!--
  Isotipo "da" estilo pixel: dos cuadrados blancos con contracaracteres
  internos, asta superior en la 'd' y descender derecho en la 'a'.
  Grilla 18x18 con shape-rendering crispEdges para bordes nitidos.
-->
<svg
  width={size}
  height={size}
  viewBox="0 0 18 18"
  aria-label="DASAT"
  shape-rendering="crispEdges"
  style={soft ? 'filter:drop-shadow(0 0 18px rgba(255,255,255,0.15))' : undefined}
>
  <!-- Asta superior de la 'd' -->
  <rect x="6" y="1" width="2" height="4" fill="#fff" />

  <!-- Cuerpo cuadrado de la 'd' con contracaracter interno -->
  <rect x="2" y="5" width="7" height="8" fill="#fff" />
  <rect x="4" y="7" width="3" height="3" fill="#1a1a1a" />

  <!-- Cuerpo cuadrado de la 'a' con contracaracter interno -->
  <rect x="10" y="5" width="7" height="8" fill="#fff" />
  <rect x="12" y="7" width="3" height="3" fill="#1a1a1a" />

  <!-- Descender derecho de la 'a' -->
  <rect x="14" y="13" width="2" height="3" fill="#fff" />
</svg>
