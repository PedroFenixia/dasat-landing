---
export interface Props { size?: number; soft?: boolean; }
const { size = 64, soft = false } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 100 100" aria-label="DASAT" style={soft ? 'filter:drop-shadow(0 0 18px var(--red-soft))' : undefined}>
  <rect x="4" y="4" width="92" height="92" fill="var(--red)" />
  <rect x="11" y="11" width="78" height="78" fill="none" stroke="#fff" stroke-width="5" />
  <g fill="#fff">
    <rect x="46" y="22" width="8" height="56" />
    <rect x="28" y="38" width="44" height="6" />
    <rect x="28" y="56" width="44" height="6" />
    <rect x="28" y="38" width="6" height="24" />
    <rect x="66" y="38" width="6" height="24" />
  </g>
</svg>
