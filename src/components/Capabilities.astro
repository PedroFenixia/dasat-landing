---
import Icon from './Icons.astro';

const SECONDARY = [
  { code: 'S-01', icon: 'solder', title: 'Microsoldadura', body: 'Reballing, sustitución de IC, reparación a nivel componente. Estación de aire caliente y microscopio trinocular.' },
  { code: 'S-02', icon: 'chip', title: 'Reparación de placas', body: 'Diagnóstico de placas electrónicas: cortocircuitos, líneas de alimentación, reflujo BGA, reescritura de eMMC.' },
] as const;
---
<section class="caps" id="capacidades">
  <div class="caps-head">
    <span class="sec-num">§ 02</span>
    <h2 class="display sm">
      Microsoldadura y placas.<br/>
      <span class="hl">Lo que casi nadie hace.</span>
    </h2>
  </div>

  <div class="caps-secondary">
    {SECONDARY.map((s) => (
      <article class="cap-card">
        <header>
          <span class="cap-code">{s.code}</span>
          <span class="cap-tag">CAPACIDAD ESPECIAL</span>
        </header>
        <div class="cap-icon"><Icon name={s.icon} width={84} height={84} /></div>
        <h3>{s.title}</h3>
        <p>{s.body}</p>
        <footer>
          <span class="cap-bullet">— Estación de aire caliente</span>
          <span class="cap-bullet">— Microscopio trinocular</span>
          <span class="cap-bullet">— Programador de eMMC</span>
        </footer>
      </article>
    ))}
  </div>
</section>
