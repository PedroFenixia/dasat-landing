---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = 'Reparación de TV en Villena · Televisores, microsoldadura · DASAT MOBILE',
  description = 'Reparación de teles y televisores en Villena (Alicante): LCD, LED, OLED, QLED. Microsoldadura, placas, fuentes, retroiluminación. Diagnóstico honesto, presupuesto cerrado y garantía. Servicio técnico en Villena, Sax, Caudete, Yecla, Elda y Alto Vinalopó.',
  canonical = 'https://www.dasat.es/',
} = Astro.props;
---

<!doctype html>
<html lang="es-ES">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />

<title>{title}</title>
<meta name="description" content={description} />
<meta name="keywords" content="reparación TV Villena, reparar televisor Villena, reparación televisores Alicante, microsoldadura Villena, servicio técnico TV Villena, reparar tele Villena, taller electrónica Villena, reparación pantalla TV, reparar OLED Villena, reparar LED Villena" />
<meta name="author" content="DASAT MOBILE SL" />
<meta name="robots" content="index, follow, max-image-preview:large" />
<meta name="googlebot" content="index, follow" />
<link rel="canonical" href={canonical} />

<meta name="language" content="Spanish" />
<meta name="geo.region" content="ES-VC" />
<meta name="geo.placename" content="Villena, Alicante" />
<meta name="geo.position" content="38.6314;-0.8656" />
<meta name="ICBM" content="38.6314, -0.8656" />

<meta property="og:type" content="website" />
<meta property="og:locale" content="es_ES" />
<meta property="og:site_name" content="DASAT MOBILE SL" />
<meta property="og:url" content={canonical} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content="https://www.dasat.es/og-image.jpg" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="DASAT MOBILE — servicio técnico de electrónica" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content="https://www.dasat.es/og-image.jpg" />

<meta name="theme-color" content="#0a0a0b" media="(prefers-color-scheme: dark)" />
<meta name="theme-color" content="#f4f3ee" media="(prefers-color-scheme: light)" />

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&family=Archivo+Narrow:wght@400;500;700&family=JetBrains+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=Bebas+Neue&display=swap" rel="stylesheet" />

<script type="application/ld+json" set:html={JSON.stringify({
